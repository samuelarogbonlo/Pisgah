# ===========================================
# Pisgah — Environment Variables
# ===========================================

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# World (Patient Auth + Verification)
NEXT_PUBLIC_WORLD_APP_ID=app_...
WORLD_RP_ID=rp_...
WORLD_SIGNING_KEY=0x...
WORLD_API_KEY=

# Dynamic (Provider Auth)
NEXT_PUBLIC_DYNAMIC_ENV_ID=...

# AgentKit (Clinic Assistant)
AGENT_PRIVATE_KEY=0x...

# ENS / NameStone
NAMESTONE_API_KEY=...

# Attestations (EAS on World Chain Sepolia)
ATTESTATION_PRIVATE_KEY=0x...
WORLD_CHAIN_SEPOLIA_RPC=https://worldchain-sepolia.g.alchemy.com/public
DIAGNOSTIC_ORDER_SCHEMA_UID=0x...
LAB_RESULT_SCHEMA_UID=0x...
PRESCRIPTION_SCHEMA_UID=0x...

# AI
OPENAI_API_KEY=sk-...

# Email
RESEND_API_KEY=re_...

# General
NEXT_PUBLIC_BASE_URL=http://localhost:3000
